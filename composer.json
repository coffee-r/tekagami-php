{
    "name": "coffee-r/tekagami-php",
    "description": "PHP library for observing HTTP request behavior and recording as JSONL for specification investigation",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5",
        "opis/json-schema": "^2.3",
        "doctrine/instantiator": "^1.5"
    },
    "autoload": {
        "psr-4": {
            "CoffeeR\\Tekagami\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CoffeeR\\Tekagami\\Tests\\": "tests/"
        }
    }
}
